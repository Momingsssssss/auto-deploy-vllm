[
  {
    "id": "01_basic_hello",
    "name": "基础: 简单问候",
    "prompt": "你好，请只回答'你好'这两个字。",
    "tools": [],
    "expected_check": "contains:你好"
  },
  {
    "id": "02_function_single_tool",
    "name": "工具: 单工具调用(天气)",
    "prompt": "上海明天会下雨吗？",
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "get_weather",
          "description": "获取指定城市的天气信息",
          "parameters": {
            "type": "object",
            "properties": {
              "location": { "type": "string", "description": "城市名称" }
            },
            "required": ["location"]
          }
        }
      }
    ],
    "expected_check": "tool_call:get_weather"
  },
  {
    "id": "03_function_multi_tools",
    "name": "工具: 多工具选择(股票 vs 天气)",
    "prompt": "我想买苹果公司的股票，现在的股价是多少？",
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "get_stock_price",
          "description": "获取特定公司的实时股票价格",
          "parameters": {
            "type": "object",
            "properties": {
              "symbol": { "type": "string", "description": "股票代码或公司名称" }
            },
            "required": ["symbol"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "search_web",
          "description": "在搜索引擎中查找通用信息",
          "parameters": {
            "type": "object",
            "properties": {
              "query": { "type": "string", "description": "搜索关键词" }
            },
            "required": ["query"]
          }
        }
      }
    ],
    "expected_check": "tool_call:get_stock_price"
  },
  {
